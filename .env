# Email Configuration for OTP (Development)
# Use Ethereal Email - Free fake SMTP for testing
# Create account at: https://ethereal.email/create

SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_username@ethereal.email
SMTP_PASS=your_password

